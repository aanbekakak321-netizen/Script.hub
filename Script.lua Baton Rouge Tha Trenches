local function IsInsideTarget(obj, targetName)
    while obj.Parent do
        obj = obj.Parent
        if obj.Name == targetName then
            return true
        end
    end
    return false
end

-- MAIN
task.spawn(function()
    while task.wait(0.1) do
        
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("ProximityPrompt") then
                
                if getgenv().AutoBag then
                    -- hanya aktifkan BagSpawn & Throw
                    if IsInsideTarget(v, "BagSpawn") or IsInsideTarget(v, "Throw") then
                        v.Enabled = true
                        v.MaxActivationDistance = 9999
                        v.HoldDuration = 0
                        
                        fireproximityprompt(v)
                    else
                        v.Enabled = false
                    end
                else
                    
                    v.Enabled = true
                end
                
            end
        end
        
    end
end)
